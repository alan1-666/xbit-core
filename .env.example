# Gateway
GATEWAY_ADDR=:8080
GATEWAY_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:5173,http://localhost:5174
GATEWAY_REQUEST_TIMEOUT=30s

# Service runtime
SERVICE_ADDR=:8081
JWT_SIGNING_KEY=dev-only-change-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
SHUTDOWN_TIMEOUT=10s
DEV_AUTH_ENABLED=true
PROVIDER_TIMEOUT=8s

# Hyperliquid provider.
# local: seeded/local provider for frontend and backend development.
# http: read from Hyperliquid /info and forward only already-signed /exchange payloads.
HYPERLIQUID_PROVIDER_MODE=local
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz

# Upstreams used by gateway. Point these at unstable/staging/prod or local services.
XBIT_UPSTREAM_CORE_GRAPHQL_URL=https://unstable-api.xbit.live/api/meme/graphql
XBIT_UPSTREAM_MEME2_GRAPHQL_URL=https://unstable-api.xbit.live/api/meme2/meme-gql
XBIT_UPSTREAM_AGENT_GRAPHQL_URL=https://unstable-api.xbit.live/api/dex-agent/graphql
XBIT_UPSTREAM_TRADING_GRAPHQL_URL=https://unstable-api.xbit.live/api/trading/trading-gql
XBIT_UPSTREAM_USER_GRAPHQL_URL=https://unstable-api.xbit.live/api/user/user-gql
XBIT_UPSTREAM_NOTIFICATION_GRAPHQL_URL=https://unstable-api.xbit.live/api/notification/notification-gql
XBIT_UPSTREAM_WALLET_GRAPHQL_URL=https://unstable-api.xbit.live/api/wallet/query
XBIT_UPSTREAM_AFFILIATE_GRAPHQL_URL=https://unstable-api.xbit.live/api/affiliate/query
XBIT_UPSTREAM_PREDICTION_GRAPHQL_URL=https://unstable-api.xbit.live/api/xp-api/predict-gql
XBIT_UPSTREAM_XP_USER_GRAPHQL_URL=https://unstable-api.xbit.live/api/xp-user-service
XBIT_UPSTREAM_DEX_HYPERTRADER_GRAPHQL_URL=https://unstable-api.xbit.live/api/dex-hypertrader/graphql/
XBIT_UPSTREAM_SYMBOL_DEX_GRAPHQL_URL=https://unstable-api.xbit.live/api/graphql-dex
XBIT_UPSTREAM_ADMIN_GRAPHQL_URL=https://unstable-api.xbit.live/api/admin/query
XBIT_UPSTREAM_LOYALTY_GRAPHQL_URL=https://unstable-api.xbit.live/api/loyalty/query
XBIT_UPSTREAM_REDPACKET_GRAPHQL_URL=https://unstable-api.xbit.live/api/campaign/red-packet-gql

# Local service examples:
# XBIT_UPSTREAM_TRADING_GRAPHQL_URL=http://localhost:8083/graphql
# XBIT_UPSTREAM_MEME2_GRAPHQL_URL=http://localhost:8084/graphql
# XBIT_UPSTREAM_CORE_GRAPHQL_URL=http://localhost:8084/graphql
# XBIT_UPSTREAM_SYMBOL_DEX_GRAPHQL_URL=http://localhost:8086/graphql
# XBIT_UPSTREAM_DEX_HYPERTRADER_GRAPHQL_URL=http://localhost:8086/graphql
# Only for isolated Hyperliquid signature smoke tests; normal user gql should stay on identity/user upstream.
# XBIT_UPSTREAM_USER_GRAPHQL_URL=http://localhost:8086/graphql

# Local infra
POSTGRES_DSN=postgres://xbit:xbit@localhost:5432/xbit?sslmode=disable
REDIS_ADDR=localhost:6379
KAFKA_BROKERS=localhost:9092
MQTT_BROKER_URL=tcp://localhost:1883
MQTT_ENABLED=false
MQTT_CLIENT_ID=xbit-stream-bridge-local
MQTT_USERNAME=
MQTT_PASSWORD=
